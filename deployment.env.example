# deployment.env.example
# ─────────────────────────────────────────────────────────────────
# BOOKWORM — HOSTINGER SHARED HOSTING ENVIRONMENT REFERENCE
# ─────────────────────────────────────────────────────────────────
#
# This file documents all environment variables used by the project.
#
# FRONTEND (Next.js static export):
#   Set NEXT_PUBLIC_API_BASE_URL BEFORE running "npm run build".
#   It gets baked into the static JS bundle at build time.
#   After building, changing this file has NO effect on the frontend.
#
# BACKEND (PHP):
#   Copy backend/config/db.production.php → backend/config/db.local.php
#   on your Hostinger server and fill in the credentials below.
#   PHP reads these at runtime, so changes take effect immediately.
# ─────────────────────────────────────────────────────────────────

# ── FRONTEND VARIABLE (baked into static build) ──────────────────
# The full URL to your backend folder on Hostinger.
# Example: https://yourdomain.com/backend
# This MUST point to the backend/ directory where api/ lives.
NEXT_PUBLIC_API_BASE_URL=https://yourdomain.com/backend

# ── BACKEND VARIABLES (set in backend/config/db.local.php) ───────
# Hostinger MySQL host is always "localhost" for shared hosting.
DB_HOST=localhost

# Your Hostinger database name (from hPanel > MySQL Databases).
# Format is typically: u123456789_databasename
DB_NAME=u123456789_bookworm

# Your Hostinger database username.
# Format is typically: u123456789_username
DB_USER=u123456789_bwuser

# Your Hostinger database password (set when creating the DB user).
DB_PASSWORD=YOUR_STRONG_PASSWORD_HERE

# ── OPTIONAL: ADMIN JWT SECRET ────────────────────────────────────
# The admin token encryption key in backend/api/admin/auth_helper.php
# Change the default value in that file before going live.
# Line: define('ADMIN_JWT_SECRET', 'YOUR-SECRET-KEY-HERE');
ADMIN_JWT_SECRET=bookworm-store-admin-super-secret-key-12345!
